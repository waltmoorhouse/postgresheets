{
  "name": "postgresheets",
  "displayName": "PostgreSQL Data Editor",
  "description": "Connect to PostgreSQL databases and edit table data in a spreadsheet-like interface",
  "version": "3.4.0",
  "publisher": "WaltMoorhouse",
  "icon": "images/icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/waltmoorhouse/postgresheets.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/index.js",
  "contributes": {
    "languages": [
      {
        "id": "postgresql",
        "aliases": [
          "PostgreSQL",
          "postgresql",
          "SQL (PostgreSQL)"
        ],
        "extensions": [
          ".psql",
          ".pgsql"
        ]
      }
    ],
    "commands": [
      {
        "command": "postgres-editor.addConnection",
        "title": "Add Connection",
        "icon": "$(add)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.editConnection",
        "title": "Edit Connection",
        "icon": "$(edit)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.deleteConnection",
        "title": "Delete Connection",
        "icon": "$(trash)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.refreshExplorer",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.openTable",
        "title": "Open Table",
        "icon": "$(table)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.connect",
        "title": "Connect",
        "icon": "$(plug)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.disconnect",
        "title": "Disconnect",
        "icon": "$(debug-disconnect)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.refreshConnection",
        "title": "Reconnect",
        "icon": "$(sync)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.cancelConnect",
        "title": "Cancel Connect",
        "icon": "$(debug-stop)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.createTable",
        "title": "Create Table",
        "icon": "$(diff-added)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.cancelAllConnects",
        "title": "Cancel All Connects",
        "icon": "$(debug-stop)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.alterTable",
        "title": "Alter Table",
        "icon": "$(edit)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.dropTable",
        "title": "Drop Table",
        "icon": "$(trash)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.exportTableAsCSV",
        "title": "Export as CSV",
        "icon": "$(export)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.importTableFromCSV",
        "title": "Import from CSV",
        "icon": "$(import)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.manageIndexes",
        "title": "Manage Indexes",
        "icon": "$(list-tree)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.managePermissions",
        "title": "Manage Permissions",
        "icon": "$(lock)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.openSqlTerminal",
        "title": "Open SQL Terminal",
        "icon": "$(terminal)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.newSqlFile",
        "title": "New PostgreSQL File",
        "icon": "$(file)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.runSqlFile",
        "title": "Run SQL File",
        "icon": "$(play)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.runSqlSelection",
        "title": "Run SQL Selection",
        "icon": "$(play)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.selectSqlDocumentConnection",
        "title": "Select SQL Connection",
        "icon": "$(plug)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.viewQueryHistory",
        "title": "View Query History",
        "icon": "$(history)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.clearQueryHistory",
        "title": "Clear Query History",
        "icon": "$(trash)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.refreshQueryHistory",
        "title": "Refresh Query History",
        "icon": "$(refresh)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.viewTableStats",
        "title": "View Table Statistics",
        "icon": "$(graph)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.backupDatabase",
        "title": "Backup Database",
        "icon": "$(cloud-download)",
        "category": "PostgreSQL"
      },
      {
        "command": "postgres-editor.restoreDatabase",
        "title": "Restore Database",
        "icon": "$(cloud-upload)",
        "category": "PostgreSQL"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "postgres-editor",
          "title": "PostgreSQL Editor",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "postgres-editor": [
        {
          "id": "postgresExplorer",
          "name": "Connections",
          "icon": "$(database)"
        },
        {
          "type": "webview",
          "id": "postgresQueryHistory",
          "name": "Query History",
          "icon": "$(history)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "postgres-editor.addConnection",
          "when": "view == postgresExplorer",
          "group": "navigation"
        },
        {
          "command": "postgres-editor.refreshExplorer",
          "when": "view == postgresExplorer",
          "group": "navigation"
        },
        {
          "command": "postgres-editor.cancelAllConnects",
          "when": "view == postgresExplorer && postgresHasConnecting",
          "group": "navigation"
        },
        {
          "command": "postgres-editor.refreshQueryHistory",
          "when": "view == postgresQueryHistory",
          "group": "navigation"
        }
      ],
      "menubar/file": [
        {
          "command": "postgres-editor.newSqlFile",
          "group": "sql"
        }
      ],
      "file/newFile": [
        {
          "command": "postgres-editor.newSqlFile",
          "group": "sql"
        }
      ],
      "editor/title": [
        {
          "command": "postgres-editor.selectSqlDocumentConnection",
          "when": "resourceLangId == sql || resourceLangId == postgresql",
          "group": "navigation"
        },
        {
          "command": "postgres-editor.runSqlSelection",
          "when": "(resourceLangId == sql || resourceLangId == postgresql) && editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "postgres-editor.runSqlFile",
          "when": "resourceLangId == sql || resourceLangId == postgresql",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "postgres-editor.connect",
          "when": "view == postgresExplorer && (viewItem == connection.disconnected || viewItem == connection.error)",
          "group": "inline@0"
        },
        {
          "command": "postgres-editor.disconnect",
          "when": "view == postgresExplorer && (viewItem == connection.connected || viewItem == connection.busy || viewItem == connection.connecting)",
          "group": "inline@1"
        },
        {
          "command": "postgres-editor.cancelConnect",
          "when": "view == postgresExplorer && viewItem == connection.connecting",
          "group": "inline@1"
        },
        {
          "command": "postgres-editor.refreshConnection",
          "when": "view == postgresExplorer && (viewItem == connection.connected || viewItem == connection.busy || viewItem == connection.error)",
          "group": "inline@2"
        },
        {
          "command": "postgres-editor.editConnection",
          "when": "view == postgresExplorer && (viewItem == connection.connected || viewItem == connection.disconnected || viewItem == connection.connecting || viewItem == connection.busy || viewItem == connection.error)",
          "group": "inline@3"
        },
        {
          "command": "postgres-editor.deleteConnection",
          "when": "view == postgresExplorer && (viewItem == connection.connected || viewItem == connection.disconnected || viewItem == connection.connecting || viewItem == connection.busy || viewItem == connection.error)",
          "group": "inline@4"
        },
        {
          "command": "postgres-editor.createTable",
          "when": "view == postgresExplorer && viewItem == schema",
          "group": "inline"
        },
        {
          "command": "postgres-editor.alterTable",
          "when": "view == postgresExplorer && viewItem == table",
          "group": "inline"
        },
        {
          "command": "postgres-editor.dropTable",
          "when": "view == postgresExplorer && viewItem == table",
          "group": "inline"
        },
        {
          "command": "postgres-editor.exportTableAsCSV",
          "when": "view == postgresExplorer && viewItem == table",
          "group": "1_table@1"
        },
        {
          "command": "postgres-editor.importTableFromCSV",
          "when": "view == postgresExplorer && viewItem == table",
          "group": "1_table@2"
        },
        {
          "command": "postgres-editor.manageIndexes",
          "when": "view == postgresExplorer && viewItem == table",
          "group": "2_manage@1"
        },
        {
          "command": "postgres-editor.managePermissions",
          "when": "view == postgresExplorer && viewItem == table",
          "group": "2_manage@2"
        },
        {
          "command": "postgres-editor.viewTableStats",
          "when": "view == postgresExplorer && viewItem == table",
          "group": "2_manage@3"
        },
        {
          "command": "postgres-editor.backupDatabase",
          "when": "view == postgresExplorer && (viewItem == connection.connected || viewItem == connection.busy)",
          "group": "3_terminal@2"
        },
        {
          "command": "postgres-editor.restoreDatabase",
          "when": "view == postgresExplorer && (viewItem == connection.connected || viewItem == connection.busy)",
          "group": "3_terminal@3"
        },
        {
          "command": "postgres-editor.openSqlTerminal",
          "when": "view == postgresExplorer && (viewItem == connection.connected || viewItem == connection.busy)",
          "group": "3_terminal@1"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "PostgreSQL Data Editor",
      "properties": {
        "postgresDataEditor.paginationSize": {
          "type": "number",
          "default": 100,
          "description": "Number of rows to display per page in the data editor."
        },
        "postgresDataEditor.batchMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable batch mode for executing changes."
        }
      }
    }
  },
  "scripts": {
    "vscode:package": "npm run vscode:prepublish && npx vsce package",
    "vscode:prepublish": "npm run build:webview && npm run build:extension && npm run clean:out && npm run validate:manifest-main",
    "compile": "tsc -p ./",
    "clean": "rm -rf dist",
    "clean:out": "rm -rf out",
    "bundle": "npx @vercel/ncc build ./out/extension.js -o dist --source-map --external vscode",
    "build:extension": "npm run compile && npm run bundle",
    "validate:manifest-main": "node -e \"const p=require('./package.json'); const fs=require('fs'); if(!p.main) { console.error('package.json missing main field'); process.exit(1); } if(!fs.existsSync(p.main)) { console.error('Main file not found:', p.main); process.exit(1); } console.log('Manifest main exists:', p.main);\"",
    "watch": "tsc -watch -p ./",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config=jest.config.cjs",
    "test:components": "jest --testPathPatterns='./test/.*\\.(spec|test)\\.(ts|js)$'",
    "test:prepare-webview": "npm ci --prefix webview",
    "test:components:ci": "npm run test:prepare-webview && node --experimental-vm-modules node_modules/.bin/jest --config=jest.config.cjs --testPathPatterns='./test/.*\\.(spec|test)\\.(ts|js)$'",
    "dev:webview": "npm --prefix webview run dev",
    "build:webview": "npm --prefix webview run build",
    "check:webview": "npm --prefix webview run check"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/svelte": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.x",
    "@types/pg": "^8.15.5",
    "@types/vscode": "^1.80.0",
    "@vercel/ncc": "^0.34.0",
    "babel-jest": "^30.2.0",
    "baseline-browser-mapping": "^2.9.8",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-mock-fs": "^1.0.2",
    "svelte": "^4.2.20",
    "svelte-focus-trap": "^1.2.0",
    "svelte-jester": "^5.0.0",
    "svelte-preprocess": "^6.0.3",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vsce": "^2.15.0"
  },
  "files": [
    "dist/**",
    "media/**",
    "images/**",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "dependencies": {
    "pg": "^8.11.0"
  }
}
